# Banco PostgreSQL/Neon (obrigatório)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# URL pública canônica, sem barra final (recomendado)
PUBLIC_SITE_URL=https://seu-dominio.com

# Servidor local
PORT=5174

# Integração opcional com GitHub App
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://seu-dominio.com/api/github/callback
GITHUB_WEBHOOK_SECRET=
GITHUB_PRIVATE_KEY_BASE64=
